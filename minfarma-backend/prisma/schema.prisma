generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
}

model Medicine {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  stock       Int
  price       Float
}